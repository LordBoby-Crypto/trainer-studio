<Window x:Class="TrainerStudio.TestGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trainer Studio Test Game" Width="980" Height="640" MinWidth="850" MinHeight="560"
        Background="#0B1020" Foreground="White" WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown" KeyUp="Window_KeyUp">
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="#F5F7FF" />
      <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
    </Style>
    <Style TargetType="Button">
      <Setter Property="Background" Value="#243052" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="13,9" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
  </Window.Resources>
  <Grid Margin="18">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="280" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.ColumnSpan="2" Margin="4,0,0,14">
      <TextBlock Text="MEMORY RANGE" FontSize="12" FontWeight="Bold" Foreground="#56E0D1" />
      <TextBlock Text="Trainer Studio controlled x64 test game" FontSize="24" FontWeight="Bold" />
      <TextBlock Text="Move with A/D or arrow keys. Jump with Space. Fire with F."
                 Foreground="#94A0B8" Margin="0,4,0,0" />
    </StackPanel>

    <Border Grid.Row="1" Background="#121A30" BorderBrush="#25304B" BorderThickness="1"
            CornerRadius="12" Margin="0,0,14,0" ClipToBounds="True">
      <Canvas x:Name="GameCanvas" Background="#11182A">
        <Rectangle Width="2000" Height="70" Fill="#1D2946" Canvas.Left="0" Canvas.Top="390" />
        <Rectangle Width="170" Height="16" Fill="#334770" Canvas.Left="130" Canvas.Top="315" />
        <Rectangle Width="160" Height="16" Fill="#334770" Canvas.Left="390" Canvas.Top="245" />
        <Ellipse x:Name="Player" Width="42" Height="42" Fill="#6C63FF"
                 Stroke="#AAA5FF" StrokeThickness="3" />
        <TextBlock Text="TRAINING RANGE" Foreground="#222D48" FontSize="48" FontWeight="Bold"
                   Canvas.Left="40" Canvas.Top="55" />
      </Canvas>
    </Border>

    <Border Grid.Row="1" Grid.Column="1" Background="#121A30" BorderBrush="#25304B"
            BorderThickness="1" CornerRadius="12" Padding="15">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <TextBlock Text="LIVE VALUES" FontSize="11" FontWeight="Bold" Foreground="#94A0B8" />
          <Grid Margin="0,12,0,18">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="30" /><RowDefinition Height="30" />
              <RowDefinition Height="30" /><RowDefinition Height="30" />
              <RowDefinition Height="30" /><RowDefinition Height="30" />
              <RowDefinition Height="30" />
            </Grid.RowDefinitions>
            <TextBlock Text="Health" /><TextBlock Grid.Column="1" x:Name="HealthText" FontWeight="Bold" />
            <TextBlock Grid.Row="1" Text="Ammo" /><TextBlock Grid.Row="1" Grid.Column="1" x:Name="AmmoText" FontWeight="Bold" />
            <TextBlock Grid.Row="2" Text="Credits" /><TextBlock Grid.Row="2" Grid.Column="1" x:Name="CreditsText" FontWeight="Bold" Foreground="#56E0D1" />
            <TextBlock Grid.Row="3" Text="Cooldown" /><TextBlock Grid.Row="3" Grid.Column="1" x:Name="CooldownText" FontWeight="Bold" />
            <TextBlock Grid.Row="4" Text="Move speed" /><TextBlock Grid.Row="4" Grid.Column="1" x:Name="SpeedText" FontWeight="Bold" />
            <TextBlock Grid.Row="5" Text="Jump height" /><TextBlock Grid.Row="5" Grid.Column="1" x:Name="JumpText" FontWeight="Bold" />
            <TextBlock Grid.Row="6" Text="Game time" /><TextBlock Grid.Row="6" Grid.Column="1" x:Name="TimeText" FontWeight="Bold" />
          </Grid>

          <TextBlock Text="CONTROLLED CHANGES" FontSize="11" FontWeight="Bold"
                     Foreground="#94A0B8" Margin="0,0,0,10" />
          <Button Content="Take 17 damage" Click="Damage_Click" />
          <Button Content="Heal to 100" Click="Heal_Click" />
          <Button Content="Earn 125 credits" Click="Earn_Click" />
          <Button Content="Spend 40 credits" Click="Spend_Click" />
          <Button Content="Reload to 30 ammo" Click="Reload_Click" />
          <Button Content="Increase jump by 1.25" Click="Jump_Click" />
          <Button Content="Reset all values" Click="Reset_Click" Background="#584367" />
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#0E1527" BorderBrush="#25304B"
            BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,13,0,0">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="Stable native test block: " Foreground="#94A0B8" />
        <TextBlock x:Name="AddressText" FontFamily="Cascadia Mono" Foreground="#56E0D1" />
        <TextBlock Text="  ·  This address is shown only to validate scanner results." Foreground="#94A0B8" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
