<Application x:Class="TrainerStudio.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="WindowBrush" Color="#090B12" />
    <SolidColorBrush x:Key="PanelBrush" Color="#111520" />
    <SolidColorBrush x:Key="PanelRaisedBrush" Color="#171C29" />
    <SolidColorBrush x:Key="BorderBrush" Color="#262D3D" />
    <SolidColorBrush x:Key="TextBrush" Color="#F2F5FA" />
    <SolidColorBrush x:Key="MutedBrush" Color="#8C96A8" />
    <SolidColorBrush x:Key="AccentBrush" Color="#6C63FF" />
    <SolidColorBrush x:Key="Accent2Brush" Color="#21D4C2" />

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
    </Style>
    <Style TargetType="Button">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="15,9" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="7"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Opacity" Value="0.86" />
        </Trigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Opacity" Value="0.38" />
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Background" Value="#0D1018" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="CaretBrush" Value="White" />
    </Style>
    <Style TargetType="ComboBox">
      <Setter Property="Foreground" Value="#10131A" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#AEB5C2" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="ItemTemplate">
        <Setter.Value>
          <DataTemplate>
            <TextBlock Text="{Binding}" Foreground="#10131A" />
          </DataTemplate>
        </Setter.Value>
      </Setter>
      <Setter Property="ItemContainerStyle">
        <Setter.Value>
          <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#10131A" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Padding" Value="9,7" />
            <Style.Triggers>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="#DFE2FF" />
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#C9CEFF" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#687080" />
                <Setter Property="Opacity" Value="0.72" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsKeyboardFocusWithin" Value="True">
          <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#F4F5FF" />
        </Trigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Foreground" Value="#687080" />
          <Setter Property="Background" Value="#D9DCE3" />
          <Setter Property="Opacity" Value="0.82" />
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="Panel" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>
  </Application.Resources>
</Application>
