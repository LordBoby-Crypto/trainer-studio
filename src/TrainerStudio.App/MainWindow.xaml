<Window x:Class="TrainerStudio.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trainer Studio" Width="1320" Height="820" MinWidth="1080" MinHeight="700"
        Background="{StaticResource WindowBrush}" WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <Style TargetType="ListBoxItem">
      <Setter Property="Padding" Value="11,9" />
      <Setter Property="Margin" Value="0,0,0,4" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#2D3155" />
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style TargetType="DataGridCell">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="10,8" />
    </Style>
    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="#171C29" />
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
      <Setter Property="Padding" Value="10,9" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="68" />
      <RowDefinition Height="*" />
      <RowDefinition Height="44" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#0D1018" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1" Padding="22,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Width="36" Height="36" CornerRadius="9" Background="{StaticResource AccentBrush}">
            <TextBlock Text="TS" FontWeight="Bold" FontSize="14"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Margin="12,0,0,0">
            <TextBlock Text="TRAINER STUDIO" FontSize="17" FontWeight="Bold" />
            <TextBlock Text="Windows x64 memory discovery workspace" FontSize="11"
                       Foreground="{StaticResource MutedBrush}" />
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Content="New" Command="{Binding NewProjectCommand}"
                  Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
          <Button Content="Open" Command="{Binding OpenProjectCommand}"
                  Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
          <Button Content="Save project" Command="{Binding SaveProjectCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="18">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280" />
        <ColumnDefinition Width="12" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="12" />
        <ColumnDefinition Width="285" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource Panel}" Padding="14">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="RUNNING PROCESSES" FontSize="11" FontWeight="Bold"
                     Foreground="{StaticResource MutedBrush}" Margin="2,0,0,10" />
          <TextBox Grid.Row="1" Text="{Binding ProcessFilter, UpdateSourceTrigger=PropertyChanged}"
                   ToolTip="Filter by process name or PID" Margin="0,0,0,9" />
          <Button Grid.Row="2" Content="Refresh processes" Command="{Binding RefreshProcessesCommand}"
                  Style="{StaticResource SecondaryButton}" Margin="0,0,0,10" />
          <ListBox Grid.Row="3" ItemsSource="{Binding Processes}"
                   SelectedItem="{Binding SelectedProcess}" Background="Transparent"
                   BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel>
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding Id, StringFormat=PID {0}}" FontSize="11"
                             Foreground="{StaticResource MutedBrush}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <Button Grid.Row="4" Content="Attach to selected" Command="{Binding AttachCommand}" Margin="0,10,0,0" />
        </Grid>
      </Border>

      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="12" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Style="{StaticResource Panel}" Padding="16">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.2*" />
              <ColumnDefinition Width="1.1*" />
              <ColumnDefinition Width="1.4*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,10,0">
              <TextBlock Text="VALUE TYPE" FontSize="10" FontWeight="Bold"
                         Foreground="{StaticResource MutedBrush}" Margin="0,0,0,5" />
              <ComboBox ItemsSource="{Binding ValueTypes}" SelectedItem="{Binding SelectedValueType}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,10,0">
              <TextBlock Text="COMPARISON" FontSize="10" FontWeight="Bold"
                         Foreground="{StaticResource MutedBrush}" Margin="0,0,0,5" />
              <ComboBox ItemsSource="{Binding ComparisonModes}" SelectedItem="{Binding SelectedComparison}" />
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="0,0,10,0">
              <TextBlock Text="VALUE" FontSize="10" FontWeight="Bold"
                         Foreground="{StaticResource MutedBrush}" Margin="0,0,0,5" />
              <TextBox Text="{Binding SearchValue, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
              <Button Content="First scan" Command="{Binding FirstScanCommand}" Margin="0,0,7,0" />
              <Button Content="Next scan" Command="{Binding NextScanCommand}" Background="{StaticResource Accent2Brush}"
                      Foreground="#071411" />
            </StackPanel>
          </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Panel}" Padding="0">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="50" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Margin="16,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="SCAN RESULTS" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"
                         Foreground="{StaticResource MutedBrush}" />
              <TextBlock Grid.Column="1" Text="{Binding ResultSummary}"
                         VerticalAlignment="Center" Foreground="{StaticResource Accent2Brush}" />
            </Grid>
            <DataGrid Grid.Row="1" ItemsSource="{Binding Candidates}" SelectedItem="{Binding SelectedCandidate}"
                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" Background="Transparent"
                      BorderThickness="0" RowBackground="#0F131D" AlternatingRowBackground="#121722"
                      BorderBrush="{StaticResource BorderBrush}">
              <DataGrid.Columns>
                <DataGridTextColumn Header="ADDRESS" Binding="{Binding Address}" Width="*" />
                <DataGridTextColumn Header="CURRENT VALUE" Binding="{Binding CurrentValue}" Width="180" />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Column="4" Style="{StaticResource Panel}" Padding="16">
        <StackPanel>
          <TextBlock Text="INSPECTOR" FontSize="11" FontWeight="Bold"
                     Foreground="{StaticResource MutedBrush}" Margin="0,0,0,16" />
          <TextBlock Text="ATTACHED PROCESS" FontSize="10" Foreground="{StaticResource MutedBrush}" />
          <TextBlock Text="{Binding AttachedProcess}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,18" />
          <TextBlock Text="SELECTED ADDRESS" FontSize="10" Foreground="{StaticResource MutedBrush}" />
          <TextBlock Text="{Binding SelectedCandidate.Address, TargetNullValue=No result selected}"
                     FontFamily="Cascadia Mono" Margin="0,4,0,14" />
          <TextBlock Text="WRITE VALUE" FontSize="10" Foreground="{StaticResource MutedBrush}" />
          <TextBox Text="{Binding WriteValue, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,8" />
          <Button Content="Write value" Command="{Binding WriteValueCommand}" Margin="0,0,0,22" />

          <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,18" />
          <TextBlock Text="SAVE DISCOVERY" FontSize="10" Foreground="{StaticResource MutedBrush}" />
          <TextBox Text="{Binding DiscoveryName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,8" />
          <Button Content="Add to project" Command="{Binding AddDiscoveryCommand}"
                  Style="{StaticResource SecondaryButton}" />

          <Border Background="#0D1018" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                  CornerRadius="8" Padding="12" Margin="0,22,0,0">
            <StackPanel>
              <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding DiscoveryCount}" Foreground="{StaticResource MutedBrush}"
                         FontSize="11" Margin="0,3,0,0" />
            </StackPanel>
          </Border>
          <TextBlock Text="Pointer paths and code tracing arrive in later milestones. Saved addresses remain experimental until restart-tested."
                     TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="11"
                     Margin="0,14,0,0" />
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="2" Background="#0D1018" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0" Padding="18,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="220" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" />
        <ProgressBar Grid.Column="1" Value="{Binding Progress}" Maximum="100" Height="5"
                     VerticalAlignment="Center" Margin="12,0" Foreground="{StaticResource Accent2Brush}" />
        <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelCommand}"
                Style="{StaticResource SecondaryButton}" Padding="10,5" />
      </Grid>
    </Border>
  </Grid>
</Window>
